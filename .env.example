# App security
SECRET_KEY=replace-with-a-random-64-char-hex-string

# Database configuration
# Option 1 (recommended): set a full DATABASE_URL directly.
#   Postgres example: postgresql://db_user:db_pass@localhost:5432/stables_db
#   SQLite example: sqlite:///./data/stables.db
DATABASE_URL=

# Option 2: use DB_DIALECT + DB_* variables (used when DATABASE_URL is empty).
# Supported values: postgresql, sqlite
DB_DIALECT=postgresql

# Used when DB_DIALECT=sqlite and DATABASE_URL is empty.
# Use :memory: for an in-memory DB.
SQLITE_DB_PATH=./data/stables.db

# Used when DB_DIALECT=postgresql and DATABASE_URL is empty.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stables_db
DB_USER=db_user
DB_PASSWORD=db_pass

# Optional: used by local Postgres Docker compose setup
POSTGRES_USER=db_user
POSTGRES_PASSWORD=db_pass
